{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "List",
      "description": "List renders an array of items, following the Ant Design List API (grid, itemLayout, size, bordered, split, header, footer). Each dataSource element is rendered via itemTemplate, or as a child widget when it carries a resourceRefId. Supersedes DataGrid.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "required": ["widgetData"],
      "additionalProperties": false,
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "grid": {
              "type": "object",
              "additionalProperties": false,
              "description": "antd List grid layout (ListGridType); presence enables grid mode",
              "properties": {
                "gutter": { "type": "integer" },
                "column": { "type": "integer" },
                "xs": { "type": "integer" },
                "sm": { "type": "integer" },
                "md": { "type": "integer" },
                "lg": { "type": "integer" },
                "xl": { "type": "integer" },
                "xxl": { "type": "integer" }
              }
            },
            "itemLayout": {
              "type": "string",
              "enum": ["horizontal", "vertical"],
              "description": "antd List itemLayout"
            },
            "size": {
              "type": "string",
              "enum": ["default", "large", "small"],
              "description": "antd List size"
            },
            "bordered": { "type": "boolean", "description": "antd List bordered" },
            "split": { "type": "boolean", "description": "antd List split" },
            "loading": { "type": "boolean", "description": "antd List loading" },
            "header": { "type": "string", "description": "antd List header (ReactNode in antd; string here)" },
            "footer": { "type": "string", "description": "antd List footer (ReactNode in antd; string here)" },
            "dataSource": {
              "type": "array",
              "description": "antd List dataSource. Each element is a data object (rendered via itemTemplate) or { resourceRefId } (rendered as a child widget).",
              "items": { "type": "object", "additionalProperties": true }
            },
            "itemTemplate": {
              "type": "object",
              "additionalProperties": false,
              "description": "serializable substitute for antd renderItem: maps a data element's fields to row slots ({dot.path}; {a|b} first-non-empty)",
              "properties": {
                "primaryText": { "type": "string" },
                "secondaryText": { "type": "string" },
                "subPrimaryText": { "type": "string" },
                "subSecondaryText": { "type": "string" },
                "icon": { "type": "string" },
                "color": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "value": { "type": "string" },
                    "map": { "type": "object", "additionalProperties": { "type": "string" } },
                    "default": { "type": "string" }
                  }
                },
                "formats": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "primaryText": { "type": "string", "enum": ["text", "datetime"] },
                    "secondaryText": { "type": "string", "enum": ["text", "datetime"] },
                    "subPrimaryText": { "type": "string", "enum": ["text", "datetime"] },
                    "subSecondaryText": { "type": "string", "enum": ["text", "datetime"] }
                  }
                }
              }
            },
            "sseEndpoint": { "type": "string", "description": "optional SSE endpoint to stream items from (Krateo extension)" },
            "sseTopic": { "type": "string", "description": "optional SSE subscription topic (Krateo extension)" },
            "prefix": { "type": "string", "description": "Filters prefix (Krateo extension)" },
            "maxItems": { "type": "integer", "description": "max items kept when streaming (Krateo extension, default 200)" }
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": { "type": "boolean" },
                  "apiVersion": { "type": "string" },
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "namespace": { "type": "string" },
                  "resource": { "type": "string" },
                  "verb": { "type": "string", "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"] }
                },
                "required": ["allowed", "id"]
              }
            }
          },
          "required": ["items"]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": ["kind", "spec", "version"]
}

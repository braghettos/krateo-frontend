{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "List",
      "description": "List renders an array of items, following the Ant Design List API (grid, itemLayout, size, bordered, split, header, footer). Each dataSource element is rendered via itemTemplate, or as a child widget when it carries a resourceRefId. Supersedes DataGrid.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "required": [
        "widgetData"
      ],
      "additionalProperties": false,
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "grid": {
              "type": "object",
              "additionalProperties": false,
              "description": "antd List grid layout (ListGridType); presence enables grid mode",
              "properties": {
                "gutter": {
                  "type": "integer"
                },
                "column": {
                  "type": "integer"
                },
                "xs": {
                  "type": "integer"
                },
                "sm": {
                  "type": "integer"
                },
                "md": {
                  "type": "integer"
                },
                "lg": {
                  "type": "integer"
                },
                "xl": {
                  "type": "integer"
                },
                "xxl": {
                  "type": "integer"
                }
              }
            },
            "itemLayout": {
              "type": "string",
              "enum": [
                "horizontal",
                "vertical"
              ],
              "description": "antd List itemLayout"
            },
            "size": {
              "type": "string",
              "enum": [
                "default",
                "large",
                "small"
              ],
              "description": "antd List size"
            },
            "bordered": {
              "type": "boolean",
              "description": "antd List bordered"
            },
            "split": {
              "type": "boolean",
              "description": "antd List split"
            },
            "loading": {
              "type": "boolean",
              "description": "antd List loading"
            },
            "header": {
              "type": "string",
              "description": "antd List header (ReactNode in antd; string here)"
            },
            "footer": {
              "type": "string",
              "description": "antd List footer (ReactNode in antd; string here)"
            },
            "dataSource": {
              "type": "array",
              "description": "antd List dataSource. Each element is a data object (rendered via itemTemplate) or { resourceRefId } (rendered as a child widget).",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "itemTemplate": {
              "type": "object",
              "additionalProperties": false,
              "description": "serializable substitute for antd renderItem: maps a data element's fields to row slots ({dot.path}; {a|b} first-non-empty)",
              "properties": {
                "primaryText": {
                  "type": "string"
                },
                "secondaryText": {
                  "type": "string"
                },
                "subPrimaryText": {
                  "type": "string"
                },
                "subSecondaryText": {
                  "type": "string"
                },
                "icon": {
                  "type": "string"
                },
                "iconVariant": {
                  "type": "string",
                  "enum": [
                    "avatar",
                    "tile",
                    "dot"
                  ],
                  "description": "leading-indicator style: avatar (solid disc + glyph, default), tile (soft-tint rounded square + glyph), dot (small status dot + halo)"
                },
                "secondaryTextAsTag": {
                  "type": "boolean",
                  "description": "render secondaryText as a soft-tint Tag pill (e.g. a category) instead of plain text"
                },
                "navigateTo": {
                  "type": "string",
                  "description": "per-item navigation target ({dot.path} template, e.g. {link}); when it resolves non-empty the row becomes clickable and navigates there (SPA route)"
                },
                "color": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "value": {
                      "type": "string"
                    },
                    "map": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      }
                    },
                    "default": {
                      "type": "string"
                    }
                  }
                },
                "formats": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "primaryText": {
                      "type": "string",
                      "enum": [
                        "text",
                        "datetime",
                        "relative"
                      ]
                    },
                    "secondaryText": {
                      "type": "string",
                      "enum": [
                        "text",
                        "datetime",
                        "relative"
                      ]
                    },
                    "subPrimaryText": {
                      "type": "string",
                      "enum": [
                        "text",
                        "datetime",
                        "relative"
                      ]
                    },
                    "subSecondaryText": {
                      "type": "string",
                      "enum": [
                        "text",
                        "datetime",
                        "relative"
                      ]
                    }
                  }
                },
                "rowActions": {
                  "type": "array",
                  "description": "per-row action controls rendered as a kebab (\u22ef) menu on each row; each entry references an action id from widgetData.actions and is fired with the row's data as the action payload (customPayload). Distinct from navigateTo (whole-row click).",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "actionId",
                      "label"
                    ],
                    "properties": {
                      "actionId": {
                        "type": "string",
                        "description": "id of an action defined in widgetData.actions to fire when this menu item is clicked"
                      },
                      "label": {
                        "type": "string",
                        "description": "menu item label"
                      },
                      "icon": {
                        "type": "string",
                        "description": "optional Font Awesome icon name for the menu item"
                      },
                      "danger": {
                        "type": "boolean",
                        "description": "render the menu item in a destructive (red) style"
                      }
                    }
                  }
                }
              }
            },
            "sseEndpoint": {
              "type": "string",
              "description": "optional SSE endpoint to stream items from (Krateo extension)"
            },
            "sseTopic": {
              "type": "string",
              "description": "optional SSE subscription topic (Krateo extension)"
            },
            "prefix": {
              "type": "string",
              "description": "Filters prefix (Krateo extension)"
            },
            "maxItems": {
              "type": "integer",
              "description": "max items kept when streaming (Krateo extension, default 200)"
            },
            "actions": {
              "description": "the actions of the widget (canonical map; see src/schemas/actions.schema.json). Referenced per-row by itemTemplate.rowActions.",
              "type": "object",
              "properties": {
                "rest": {
                  "type": "array",
                  "description": "rest api call actions triggered by the widget",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "unique identifier for the action"
                      },
                      "resourceRefId": {
                        "type": "string",
                        "description": "the identifier of the k8s custom resource that should be represented"
                      },
                      "requireConfirmation": {
                        "type": "boolean",
                        "description": "whether user confirmation is required before triggering the action"
                      },
                      "errorMessage": {
                        "type": "string",
                        "description": "a message that will be displayed inside a toast in case of error"
                      },
                      "successMessage": {
                        "type": "string",
                        "description": "a message that will be displayed inside a toast in case of success"
                      },
                      "onSuccessNavigateTo": {
                        "type": "string",
                        "description": "url to navigate to after successful execution"
                      },
                      "onEventNavigateTo": {
                        "type": "object",
                        "required": [
                          "eventReason",
                          "url"
                        ],
                        "additionalProperties": false,
                        "description": "conditional navigation triggered by a specific event",
                        "properties": {
                          "eventReason": {
                            "type": "string",
                            "description": "identifier of the awaited event reason"
                          },
                          "url": {
                            "type": "string",
                            "description": "url to navigate to when the event is received"
                          },
                          "timeout": {
                            "type": "integer",
                            "description": "the timeout in seconds to wait for the event",
                            "default": 50
                          },
                          "reloadRoutes": {
                            "type": "boolean"
                          },
                          "loadingMessage": {
                            "type": "string",
                            "description": "message to display while waiting for the event"
                          }
                        }
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "rest"
                        ],
                        "description": "type of action to execute"
                      },
                      "headers": {
                        "description": "array of headers as strings, format 'key: value'",
                        "type": "array",
                        "items": {
                          "type": "string",
                          "description": "key and value as a single, example: 'x-custom-header: value'"
                        }
                      },
                      "payload": {
                        "type": "object",
                        "additionalProperties": true,
                        "description": "static payload sent with the request"
                      },
                      "payloadToOverride": {
                        "type": "array",
                        "description": "list of payload fields to override dynamically",
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "name",
                            "value"
                          ],
                          "properties": {
                            "name": {
                              "type": "string",
                              "description": "name of the field to override"
                            },
                            "value": {
                              "type": "string",
                              "description": "value to use for overriding the field"
                            }
                          }
                        }
                      },
                      "loading": {
                        "type": "object",
                        "properties": {
                          "display": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "display"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "required": [
                      "headers",
                      "id",
                      "type",
                      "resourceRefId"
                    ]
                  }
                },
                "navigate": {
                  "type": "array",
                  "description": "client-side navigation actions",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "unique identifier for the action"
                      },
                      "loading": {
                        "type": "object",
                        "properties": {
                          "display": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "display"
                        ],
                        "additionalProperties": false
                      },
                      "path": {
                        "description": "the identifier of the route to navigate to",
                        "type": "string"
                      },
                      "resourceRefId": {
                        "type": "string",
                        "description": "the identifier of the k8s custom resource that should be represented"
                      },
                      "requireConfirmation": {
                        "type": "boolean",
                        "description": "whether user confirmation is required before navigating"
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "navigate"
                        ],
                        "description": "type of navigation action"
                      }
                    },
                    "required": [
                      "id",
                      "type"
                    ]
                  }
                },
                "openDrawer": {
                  "type": "array",
                  "description": "actions to open side drawer components",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "unique identifier for the drawer action"
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "openDrawer"
                        ],
                        "description": "type of drawer action"
                      },
                      "resourceRefId": {
                        "type": "string",
                        "description": "the identifier of the k8s custom resource that should be represented"
                      },
                      "requireConfirmation": {
                        "type": "boolean",
                        "description": "whether user confirmation is required before opening"
                      },
                      "size": {
                        "type": "string",
                        "enum": [
                          "default",
                          "large"
                        ],
                        "description": "drawer size to be displayed"
                      },
                      "title": {
                        "type": "string",
                        "description": "title shown in the drawer header"
                      },
                      "loading": {
                        "type": "object",
                        "properties": {
                          "display": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "display"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "required": [
                      "id",
                      "type",
                      "resourceRefId"
                    ]
                  }
                },
                "openModal": {
                  "type": "array",
                  "description": "actions to open modal dialog components",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "unique identifier for the modal action"
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "openModal"
                        ],
                        "description": "type of modal action"
                      },
                      "resourceRefId": {
                        "type": "string",
                        "description": "the identifier of the k8s custom resource that should be represented"
                      },
                      "requireConfirmation": {
                        "type": "boolean",
                        "description": "whether user confirmation is required before opening"
                      },
                      "title": {
                        "type": "string",
                        "description": "title shown in the modal header"
                      },
                      "loading": {
                        "type": "object",
                        "properties": {
                          "display": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "display"
                        ],
                        "additionalProperties": false
                      },
                      "customWidth": {
                        "description": "the custom width of the value, which should be used by setting the 'custom' value inside the 'size' property",
                        "type": "string"
                      },
                      "size": {
                        "description": "sets the Modal size, 'default' is 520px, 'large' is 80% of the screen width, 'fullscreen' is 100% of the screen width, 'custom' should be used with the 'customWidth' property",
                        "type": "string",
                        "enum": [
                          "default",
                          "large",
                          "fullscreen",
                          "custom"
                        ]
                      }
                    },
                    "required": [
                      "id",
                      "type",
                      "resourceRefId"
                    ]
                  }
                }
              },
              "additionalProperties": false
            },
            "watch": {
              "description": "live-refresh watch: involvedObject(s) this widget is tied to (see src/schemas/watch.schema.json). A matching k8s event refetches the widget.",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "apiVersion",
                  "kind"
                ],
                "properties": {
                  "apiVersion": {
                    "type": "string",
                    "description": "group/version, e.g. composition.krateo.io/v1alpha1"
                  },
                  "kind": {
                    "type": "string",
                    "description": "e.g. DemoClaim"
                  },
                  "namespace": {
                    "type": "string",
                    "description": "scope to a namespace; omit to match any"
                  },
                  "name": {
                    "type": "string",
                    "description": "a specific object; omit to match any object of this kind (\"GVR-level\")"
                  }
                }
              }
            }
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "required": [
                  "allowed",
                  "id"
                ]
              }
            }
          },
          "required": [
            "items"
          ]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "namespace"
          ],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": [
    "kind",
    "spec",
    "version"
  ]
}
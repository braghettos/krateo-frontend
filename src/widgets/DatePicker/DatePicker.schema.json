{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "default": "v1beta1" },
    "kind": {
      "default": "DatePicker",
      "description": "DatePicker is a form-control widget wrapping Ant Design DatePicker. It renders inside a Form widget's context and binds its value by `name`. Values are ISO date strings (converted to/from Day.js).",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "required": ["widgetData"],
      "additionalProperties": false,
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "description": "form field key — antd Form.Item `name`" },
            "label": { "type": "string", "description": "antd Form.Item `label`" },
            "required": { "type": "boolean", "description": "add a required validation rule" },
            "defaultValue": { "type": "string", "description": "initial date as an ISO string (parsed via Day.js into Form.Item `initialValue`)" },
            "placeholder": { "type": "string", "description": "antd DatePicker `placeholder`" },
            "picker": { "type": "string", "enum": ["date", "week", "month", "quarter", "year"], "description": "antd DatePicker `picker`" },
            "format": { "type": "string", "description": "antd DatePicker `format` (display format)" },
            "size": { "type": "string", "enum": ["small", "middle", "large"], "description": "antd DatePicker `size`" },
            "disabled": { "type": "boolean", "description": "antd DatePicker `disabled`" }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": ["kind", "spec", "version"]
}

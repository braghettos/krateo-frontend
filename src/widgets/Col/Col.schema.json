{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "widget version",
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "Col",
      "description": "Col is a layout component that arranges its children in a vertical stack, aligning them one above the other with spacing between them",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "required": ["allowedResources", "items"],
          "properties": {
            "allowedResources": {
              "description": "the list of resources that are allowed to be children of this widget or referenced by it",
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "barcharts",
                  "flexes",
                  "buttons",
                  "buttongroups",
                  "cols",
                  "listies",
                  "filters",
                  "flowcharts",
                  "forms",
                  "linecharts",
                  "markdowns",
                  "cards",
                  "paragraphs",
                  "piecharts",
                  "rangepickers",
                  "rows",
                  "statistics",
                  "tables",
                  "tabs",
                  "tags",
                  "yamlviewers"
                ]
              }
            },
            "items": {
              "description": "the items of the column",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["resourceRefId"],
                "properties": {
                  "resourceRefId": {
                    "description": "the identifier of the k8s Custom Resource that should be represented, usually a widget",
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "span": {
              "description": "antd Col span — cells occupied, 0 (hidden) to 24 (full width). Renamed from `size`, which is still accepted.",
              "type": "integer",
              "minimum": 0,
              "maximum": 24
            },
            "offset": { "type": "integer", "description": "antd Col offset", "minimum": 0, "maximum": 24 },
            "order": { "type": "integer", "description": "antd Col order" },
            "flex": { "type": "string", "description": "antd Col flex" },
            "xs": { "type": "integer", "description": "antd Col xs span", "minimum": 0, "maximum": 24 },
            "sm": { "type": "integer", "description": "antd Col sm span", "minimum": 0, "maximum": 24 },
            "md": { "type": "integer", "description": "antd Col md span", "minimum": 0, "maximum": 24 },
            "lg": { "type": "integer", "description": "antd Col lg span", "minimum": 0, "maximum": 24 },
            "xl": { "type": "integer", "description": "antd Col xl span", "minimum": 0, "maximum": 24 },
            "xxl": { "type": "integer", "description": "antd Col xxl span", "minimum": 0, "maximum": 24 }
          },
          "additionalProperties": false
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": ["page", "perPage"]
                  }
                },
                "required": ["id"]
              }
            }
          },
          "required": ["items"]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData", "resourcesRefs"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

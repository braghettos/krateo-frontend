{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "Table",
      "description": "Table displays structured data with customizable columns and pagination",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "required": [
            "allowedResources",
            "data",
            "columns"
          ],
          "properties": {
            "allowedResources": {
              "description": "the list of resources that are allowed to be children of this widget or referenced by it",
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "barcharts",
                  "buttons",
                  "buttongroups",
                  "filters",
                  "flowcharts",
                  "linecharts",
                  "markdowns",
                  "paragraphs",
                  "piecharts",
                  "rangepickers",
                  "yamlviewers"
                ]
              }
            },
            "columns": {
              "description": "configuration of the table's columns",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "color": {
                    "description": "the color of the value (or the icon) to be represented",
                    "type": "string",
                    "enum": [
                      "blue",
                      "darkBlue",
                      "orange",
                      "gray",
                      "red",
                      "green",
                      "violet"
                    ]
                  },
                  "title": {
                    "description": "column header label",
                    "type": "string"
                  },
                  "valueKey": {
                    "description": "key used to extract the value from row data",
                    "type": "string"
                  }
                },
                "required": [
                  "valueKey",
                  "title"
                ],
                "additionalProperties": false
              }
            },
            "dataSource": {
              "type": "array",
              "description": "antd Table dataSource \u2014 the table rows (renamed from `data`; `data` still accepted for back-compat)",
              "items": {
                "type": "array",
                "description": "Row represented as array of cells",
                "items": {
                  "type": "object",
                  "properties": {
                    "valueKey": {
                      "description": "the key of the column this cell belongs to",
                      "type": "string"
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "jsonSchemaType",
                        "icon",
                        "widget",
                        "tag",
                        "bar",
                        "conditions"
                      ],
                      "description": "type of cell value. `tag` renders the stringValue as a colored antd Tag (use the cell `color`). `bar` renders a reconciliation-rail Progress gauge (stringValue = percent 0-100, `color` = bar/state color, amber target-tick at 100%). `conditions` renders `arrayValue` (an array of {type,status}) as small status pills, each coloured cyan (True) / crimson (False)."
                    },
                    "color": {
                      "type": "string",
                      "description": "per-cell color — for a `tag` cell, an antd Tag color (e.g. green / red / gold / blue); for a jsonSchemaType cell it overrides the column color. Lets each row carry its own color (e.g. status)."
                    },
                    "format": {
                      "type": "string",
                      "enum": [
                        "relative",
                        "date",
                        "datetime"
                      ],
                      "description": "optional display format for a string value — `relative` (e.g. \"14d ago\"), `date`, or `datetime`. The raw value stays in the data; only the rendering changes."
                    },
                    "resourceRefId": {
                      "type": "string",
                      "description": "used if kind = widget"
                    },
                    "type": {
                      "type": "string",
                      "enum": [
                        "string",
                        "number",
                        "integer",
                        "decimal",
                        "boolean",
                        "array",
                        "null"
                      ],
                      "description": "used if kind = jsonSchemaType"
                    },
                    "stringValue": {
                      "type": "string",
                      "description": "value if type = string"
                    },
                    "numberValue": {
                      "type": "integer",
                      "description": "value if type = number or integer"
                    },
                    "decimalValue": {
                      "type": "string",
                      "description": "value if type = number or decimal"
                    },
                    "booleanValue": {
                      "type": "boolean",
                      "description": "value if type = boolean"
                    },
                    "arrayValue": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "value if type = array"
                    }
                  },
                  "required": [
                    "valueKey",
                    "kind"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "pagination": {
              "type": "object",
              "additionalProperties": false,
              "description": "antd Table pagination config (subproperties mirror antd).",
              "properties": {
                "pageSize": {
                  "type": "integer",
                  "description": "number of rows per page"
                },
                "defaultPageSize": {
                  "type": "integer",
                  "description": "default page size"
                },
                "total": {
                  "type": "integer",
                  "description": "server-side pagination: the TOTAL row count across all pages (the widget's `dataSource` holds only the current page/window). Set by the widgetDataTemplate from the full list length so the pager renders the correct number of pages. When present, the Table uses controlled server-side pagination (each page fetched on demand) instead of client-side slicing of dataSource."
                },
                "current": {
                  "type": "integer",
                  "description": "server-side pagination: the 1-based current page (controlled). Usually driven by the request `page` param, not the CR."
                },
                "hideOnSinglePage": {
                  "type": "boolean",
                  "description": "hide the pager when there is a single page"
                },
                "simple": {
                  "type": "boolean",
                  "description": "use the simple pager"
                },
                "position": {
                  "type": "array",
                  "description": "pager position(s)",
                  "items": {
                    "type": "string",
                    "enum": [
                      "topLeft",
                      "topCenter",
                      "topRight",
                      "bottomLeft",
                      "bottomCenter",
                      "bottomRight"
                    ]
                  }
                }
              }
            },
            "bordered": {
              "type": "boolean",
              "description": "antd Table bordered"
            },
            "size": {
              "type": "string",
              "enum": [
                "large",
                "middle",
                "small"
              ],
              "description": "antd Table size"
            },
            "prefix": {
              "description": "it's the filters prefix to get right values",
              "type": "string"
            },
            "rowNavigateTo": {
              "description": "optional route path to navigate to on row click; `{valueKey}` placeholders are filled from that row's cells (e.g. /compositions/{ns}/{name})",
              "type": "string"
            },
            "watch": {
              "description": "live-refresh watch: involvedObject(s) this widget is tied to (see src/schemas/watch.schema.json). A matching k8s event refetches the widget.",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "apiVersion",
                  "kind"
                ],
                "properties": {
                  "apiVersion": {
                    "type": "string",
                    "description": "group/version, e.g. composition.krateo.io/v1alpha1"
                  },
                  "kind": {
                    "type": "string",
                    "description": "e.g. DemoClaim"
                  },
                  "namespace": {
                    "type": "string",
                    "description": "scope to a namespace; omit to match any"
                  },
                  "name": {
                    "type": "string",
                    "description": "a specific object; omit to match any object of this kind (\"GVR-level\")"
                  }
                }
              }
            }
          },
          "additionalProperties": false
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "page",
                      "perPage"
                    ]
                  }
                },
                "required": [
                  "allowed",
                  "id"
                ]
              }
            }
          },
          "required": [
            "items"
          ]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "name",
            "namespace"
          ]
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "additionalProperties": false
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": [
        "widgetData"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "kind",
    "spec",
    "version"
  ]
}
{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "Paragraph",
      "description": "Paragraph is a simple component used to display a block of text",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "required": ["text"],
          "properties": {
            "text": {
              "description": "the content of the paragraph (the antd Typography children, as text)",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": ["secondary", "success", "warning", "danger"],
              "description": "antd Typography type"
            },
            "strong": { "type": "boolean", "description": "antd Typography strong" },
            "italic": { "type": "boolean", "description": "antd Typography italic" },
            "underline": { "type": "boolean", "description": "antd Typography underline" },
            "delete": { "type": "boolean", "description": "antd Typography delete (strikethrough)" },
            "code": { "type": "boolean", "description": "antd Typography code" },
            "mark": { "type": "boolean", "description": "antd Typography mark (highlight)" },
            "disabled": { "type": "boolean", "description": "antd Typography disabled" },
            "copyable": { "type": "boolean", "description": "antd Typography copyable" },
            "ellipsis": { "type": "boolean", "description": "antd Typography ellipsis" }
          },
          "additionalProperties": false
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

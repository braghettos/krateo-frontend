{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "Steps",
      "description": "Steps displays a sequence of numbered steps that guide the user through a process",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "required": ["items"],
          "additionalProperties": false,
          "properties": {
            "current": {
              "type": "integer",
              "description": "the index of the current step (0-based)"
            },
            "orientation": {
              "type": "string",
              "enum": ["horizontal", "vertical"],
              "description": "the layout orientation of the steps (antd Steps `orientation`)"
            },
            "size": {
              "type": "string",
              "enum": ["default", "small"],
              "description": "the size of the steps"
            },
            "status": {
              "type": "string",
              "enum": ["wait", "process", "finish", "error"],
              "description": "the status of the current step"
            },
            "titlePlacement": {
              "type": "string",
              "enum": ["horizontal", "vertical"],
              "description": "where the title is placed relative to the step icon (antd Steps `titlePlacement`)"
            },
            "type": {
              "type": "string",
              "enum": ["default", "navigation", "inline"],
              "description": "the visual type of the steps"
            },
            "items": {
              "type": "array",
              "description": "the steps to display",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["title"],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "the title of the step"
                  },
                  "eyebrow": {
                    "type": "string",
                    "description": "a short eyebrow label shown ABOVE the title (e.g. `Step 1`) — rendered mono/uppercase"
                  },
                  "description": {
                    "type": "string",
                    "description": "the description of the step"
                  },
                  "subTitle": {
                    "type": "string",
                    "description": "the subtitle of the step"
                  },
                  "status": {
                    "type": "string",
                    "enum": ["wait", "process", "finish", "error"],
                    "description": "the status of this step"
                  },
                  "icon": {
                    "type": "string",
                    "description": "a font awesome icon name for the step (eg: `fa-user`)"
                  }
                }
              }
            }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "page",
                      "perPage"
                    ]
                  }
                },
                "required": [
                  "id"
                ]
              }
            }
          },
          "required": [
            "items"
          ]
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "PieChart",
      "description": "PieChart wraps the @ant-design/charts Pie component (AntV G2). It mirrors that library's data + field-mapping API.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "required": ["data", "angleField", "colorField"],
          "description": "@ant-design/charts Pie config (AntV G2)",
          "properties": {
            "data": {
              "type": "array",
              "description": "chart data records (G2 `data`)",
              "items": { "type": "object", "additionalProperties": true }
            },
            "angleField": { "type": "string", "description": "field mapped to the slice value / angle (G2 `angleField`)" },
            "colorField": { "type": "string", "description": "field mapped to color / category (G2 `colorField`)" },
            "colorMap": { "type": "object", "additionalProperties": { "type": "string" }, "description": "map each colorField category to a Krateo palette color name (e.g. {\"Healthy\":\"green\",\"Failed\":\"red\"}); sets the G2 color scale domain/range for semantic slice colors" },
            "innerRadius": { "type": "integer", "description": "donut hole as a percentage of the radius, 0-100 (maps to antd Pie `innerRadius` ÷ 100); omit for a full pie" },
            "legend": { "type": "boolean", "description": "show the legend; false hides it (G2 `legend`)" },
            "title": { "type": "string", "description": "chart title (G2 `title`)" },
            "height": { "type": "integer", "description": "fixed height in px (G2 `height`); omit to autofit" }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "page",
                      "perPage"
                    ]
                  }
                },
                "required": [
                  "allowed",
                  "id"
                ]
              }
            }
          },
          "required": [
            "items"
          ]
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

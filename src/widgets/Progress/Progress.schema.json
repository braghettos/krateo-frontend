{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "Progress",
      "description": "Progress displays the completion status of an operation as a line, circle or dashboard gauge",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "required": ["percent"],
          "additionalProperties": false,
          "properties": {
            "percent": {
              "type": "integer",
              "description": "the completion percentage (0-100)"
            },
            "type": {
              "type": "string",
              "enum": ["line", "circle", "dashboard"],
              "description": "the visual type of the progress indicator"
            },
            "status": {
              "type": "string",
              "enum": ["success", "exception", "normal", "active"],
              "description": "the status of the progress indicator"
            },
            "strokeColor": {
              "type": "string",
              "enum": ["blue", "darkBlue", "orange", "gray", "red", "green", "violet"],
              "description": "the color of the progress stroke"
            },
            "showInfo": {
              "type": "boolean",
              "description": "whether to display the progress value text"
            },
            "size": {
              "type": "string",
              "enum": ["default", "small"],
              "description": "the size of the progress indicator"
            },
            "steps": {
              "type": "integer",
              "description": "render the progress as a discrete number of steps"
            },
            "label": {
              "type": "string",
              "description": "optional primary readout rendered below the indicator, tinted in the strokeColor (e.g. a circle gauge's \"Healthy · 100% converged\" headline)"
            },
            "description": {
              "type": "string",
              "description": "optional secondary readout (muted graphite) rendered under `label` (e.g. \"all conditions True\")"
            }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "page",
                      "perPage"
                    ]
                  }
                },
                "required": [
                  "allowed",
                  "id"
                ]
              }
            }
          },
          "required": [
            "items"
          ]
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

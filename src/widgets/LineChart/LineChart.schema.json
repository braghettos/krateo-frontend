{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "LineChart",
      "description": "LineChart wraps the @ant-design/charts Line component (AntV G2). It mirrors that library's data + field-mapping API: pass a flat `data` array and map fields to positions/color.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "required": ["data", "xField", "yField"],
          "description": "@ant-design/charts Line config (AntV G2)",
          "properties": {
            "data": {
              "type": "array",
              "description": "chart data records (G2 `data`)",
              "items": { "type": "object", "additionalProperties": true }
            },
            "xField": { "type": "string", "description": "field mapped to the x position (G2 `xField`)" },
            "yField": { "type": "string", "description": "field mapped to the y position (G2 `yField`)" },
            "colorField": { "type": "string", "description": "field mapped to color / series (G2 `colorField`)" },
            "shapeField": { "type": "string", "description": "line shape, e.g. 'smooth' or 'line' (G2 `shapeField`)" },
            "stack": { "type": "boolean", "description": "stack the series (G2 `stack`)" },
            "legend": { "type": "boolean", "description": "show the legend; false hides it (G2 `legend`)" },
            "title": { "type": "string", "description": "chart title (G2 `title`)" },
            "height": { "type": "integer", "description": "fixed height in px (G2 `height`); omit to autofit" }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

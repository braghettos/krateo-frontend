{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "widget version",
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "type": "string",
      "description": "name of the k8s Custom Resource",
      "default": "Flex"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "description": "the data that will be passed to the widget on the frontend",
          "type": "object",
          "required": ["allowedResources", "items"],
          "properties": {
            "allowedResources": {
              "description": "the list of resources that are allowed to be children of this widget or referenced by it",
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "barcharts",
                  "buttons",
                  "buttongroups",
                  "cards",
                  "cols",
                  "eventlists",
                  "filters",
                  "flexes",
                  "flowcharts",
                  "forms",
                  "images",
                  "linecharts",
                  "lists",
                  "markdowns",
                  "menus",
                  "paragraphs",
                  "piecharts",
                  "rangepickers",
                  "rows",
                  "statistics",
                  "steps",
                  "tables",
                  "tabs",
                  "tags",
                  "yamlviewers"
                ]
              }
            },
            "vertical": {
              "description": "antd Flex vertical (column direction)",
              "type": "boolean"
            },
            "justify": {
              "description": "antd Flex justify (CSS justify-content)",
              "enum": ["flex-start", "flex-end", "center", "space-between", "space-around", "space-evenly"],
              "type": "string"
            },
            "align": {
              "description": "antd Flex align (CSS align-items)",
              "enum": ["flex-start", "flex-end", "center", "stretch", "baseline"],
              "type": "string"
            },
            "gap": {
              "description": "antd Flex gap: a SizeType preset string (small/middle/large) or a numeric pixel value",
              "type": ["string", "integer"]
            },
            "wrap": {
              "description": "antd Flex wrap",
              "type": "boolean"
            },
            "items": {
              "description": "the child widgets rendered inside the Flex",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["resourceRefId"],
                "properties": {
                  "resourceRefId": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": { "type": "boolean" },
                  "apiVersion": { "type": "string" },
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "namespace": { "type": "string" },
                  "payload": { "type": "object" },
                  "resource": { "type": "string" },
                  "verb": {
                    "type": "string",
                    "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"]
                  }
                },
                "required": ["allowed", "id"]
              }
            }
          },
          "required": ["items"]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          },
          "additionalProperties": false
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData", "resourcesRefs"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "widget version",
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "Tabs",
      "description": "Tabs display a set of tab items for navigation or content grouping",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "description": "the data that will be passed to the widget on the frontend",
          "type": "object",
          "required": ["allowedResources", "items"],
          "properties": {
            "type": { "type": "string", "enum": ["line", "card", "editable-card"], "description": "antd Tabs type" },
            "size": { "type": "string", "enum": ["small", "middle", "large"], "description": "antd Tabs size" },
            "tabPlacement": { "type": "string", "enum": ["top", "end", "bottom", "start"], "description": "antd Tabs tabPlacement" },
            "centered": { "type": "boolean", "description": "antd Tabs centered" },
            "allowedResources": {
              "description": "the list of resources that are allowed to be children of this widget or referenced by it",
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "barcharts",
                  "buttons",
                  "buttongroups",
                  "cols",
                  "listies",
                  "filters",
                  "flowcharts",
                  "forms",
                  "linecharts",
                  "markdowns",
                  "cards",
                  "paragraphs",
                  "piecharts",
                  "rangepickers",
                  "rows",
                  "tables",
                  "tabs",
                  "yamlviewers"
                ]
              }
            },
            "items": {
              "type": "array",
              "description": "the items of the tab list",
              "items": {
                "type": "object",
                "required": ["resourceRefId"],
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "text displayed on the tab"
                  },
                  "resourceRefId": {
                    "type": "string",
                    "description": "the identifier of the k8s custom resource represented by the tab content"
                  },
                  "title": {
                    "type": "string",
                    "description": "optional title to be displayed inside the tab"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": ["page", "perPage"]
                  }
                },
                "required": ["id"]
              }
            }
          },
          "required": ["items"]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": ["name", "namespace"]
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "additionalProperties": false
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["widgetData"],
      "additionalProperties": false
    }
  },
  "required": ["kind", "spec", "version"]
}

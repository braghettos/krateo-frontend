{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "default": "v1beta1" },
    "kind": {
      "default": "Input",
      "description": "Input is a form-control widget wrapping Ant Design Input. It renders inside a Form widget's context and binds its value by `name`.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "required": ["widgetData"],
      "additionalProperties": false,
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "description": "form field key — antd Form.Item `name` (collected on submit)" },
            "label": { "type": "string", "description": "antd Form.Item `label`" },
            "required": { "type": "boolean", "description": "add a required validation rule to the field" },
            "defaultValue": { "type": "string", "description": "antd Form.Item `initialValue`" },
            "placeholder": { "type": "string", "description": "antd Input `placeholder`" },
            "type": { "type": "string", "enum": ["text", "password", "email", "number", "tel", "url"], "description": "antd Input `type`" },
            "size": { "type": "string", "enum": ["small", "middle", "large"], "description": "antd Input `size`" },
            "disabled": { "type": "boolean", "description": "antd Input `disabled`" },
            "allowClear": { "type": "boolean", "description": "antd Input `allowClear`" },
            "maxLength": { "type": "integer", "description": "antd Input `maxLength`" },
            "queryParam": { "type": "string", "description": "when set, the Input is a STANDALONE URL-query-bound SEARCH box (antd Input.Search), NOT a Form control: submitting (Enter / search button) writes ?<queryParam>= into the URL → extras, so a data source can filter server-side in its RESTAction jq (e.g. `.q`). Clearing removes the param." }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "page",
                      "perPage"
                    ]
                  }
                },
                "required": [
                  "allowed",
                  "id"
                ]
              }
            }
          },
          "required": [
            "items"
          ]
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": ["kind", "spec", "version"]
}

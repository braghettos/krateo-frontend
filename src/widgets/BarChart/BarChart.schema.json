{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "BarChart",
      "description": "BarChart wraps the @ant-design/charts Column component (AntV G2 \u2014 vertical bars). It mirrors that library's data + field-mapping API.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "data",
            "xField",
            "yField"
          ],
          "description": "@ant-design/charts Column config (AntV G2)",
          "properties": {
            "data": {
              "type": "array",
              "description": "chart data records (G2 `data`)",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "xField": {
              "type": "string",
              "description": "field mapped to the category axis (G2 `xField`)"
            },
            "yField": {
              "type": "string",
              "description": "field mapped to the value axis (G2 `yField`)"
            },
            "colorField": {
              "type": "string",
              "description": "field mapped to color / series (G2 `colorField`)"
            },
            "stack": {
              "type": "boolean",
              "description": "stack series sharing an x value (G2 `stack`)"
            },
            "group": {
              "type": "boolean",
              "description": "group series side-by-side at each x value (G2 `group`)"
            },
            "legend": {
              "type": "boolean",
              "description": "show the legend; false hides it (G2 `legend`)"
            },
            "title": {
              "type": "string",
              "description": "chart title (G2 `title`)"
            },
            "height": {
              "type": "integer",
              "description": "fixed height in px (G2 `height`); omit to autofit"
            },
            "watch": {
              "description": "live-refresh watch: involvedObject(s) this widget is tied to (see src/schemas/watch.schema.json). A matching k8s event refetches the widget.",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "apiVersion",
                  "kind"
                ],
                "properties": {
                  "apiVersion": {
                    "type": "string",
                    "description": "group/version, e.g. composition.krateo.io/v1alpha1"
                  },
                  "kind": {
                    "type": "string",
                    "description": "e.g. DemoClaim"
                  },
                  "namespace": {
                    "type": "string",
                    "description": "scope to a namespace; omit to match any"
                  },
                  "name": {
                    "type": "string",
                    "description": "a specific object; omit to match any object of this kind (\"GVR-level\")"
                  }
                }
              }
            }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "name",
            "namespace"
          ]
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": {
                "type": "string"
              },
              "expression": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": {
                    "type": "boolean"
                  },
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": {
                        "type": "integer"
                      },
                      "page": {
                        "type": "integer"
                      },
                      "perPage": {
                        "type": "integer"
                      },
                      "continue": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "page",
                      "perPage"
                    ]
                  }
                },
                "required": [
                  "id"
                ]
              }
            }
          },
          "required": [
            "items"
          ]
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": {
                "type": "string"
              },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "namespace": {
                    "type": "string"
                  },
                  "payload": {
                    "type": "object"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "verb": {
                    "type": "string",
                    "enum": [
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE",
                      "GET"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "widgetData"
      ]
    }
  },
  "required": [
    "kind",
    "spec",
    "version"
  ]
}
{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "v1beta1"
    },
    "kind": {
      "default": "AppShell",
      "description": "AppShell is the portal layout: a sidebar (logo + nav) and a header (left/right slots) around a central content area. Each slot references a child widget.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "required": ["widgetData"],
      "additionalProperties": false,
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "logoSrc": {
              "type": "string",
              "description": "the logo image URL shown at the top of the sidebar"
            },
            "sidebar": {
              "type": "string",
              "description": "resourceRefId of the widget rendered in the sidebar (typically a NavMenu)"
            },
            "headerLeft": {
              "type": "array",
              "description": "resourceRefIds of the widgets rendered on the left of the header",
              "items": { "type": "string" }
            },
            "headerRight": {
              "type": "array",
              "description": "resourceRefIds of the widgets rendered on the right of the header",
              "items": { "type": "string" }
            },
            "content": {
              "type": "string",
              "description": "resourceRefId of the widget rendered in the central content area"
            }
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": { "type": "boolean" },
                  "apiVersion": { "type": "string" },
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "namespace": { "type": "string" },
                  "resource": { "type": "string" },
                  "verb": {
                    "type": "string",
                    "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"]
                  }
                },
                "required": ["allowed", "id"]
              }
            }
          },
          "required": ["items"]
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": ["kind", "spec", "version"]
}

{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "default": "v1beta1" },
    "kind": {
      "default": "RangePicker",
      "description": "RangePicker wraps Ant Design DatePicker.RangePicker as a standalone URL-bound filter (NOT a Form control). The selected [start, end] window is written to the `from`/`to` query params (epoch seconds) plus `range=custom`, so a data source can time-window server-side via request extras. Clearing removes those params.",
      "type": "string"
    },
    "spec": {
      "type": "object",
      "required": ["widgetData"],
      "additionalProperties": false,
      "properties": {
        "widgetData": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "placeholder": {
              "type": "array",
              "items": { "type": "string" },
              "description": "antd RangePicker `placeholder` ([start, end])"
            },
            "format": { "type": "string", "description": "antd RangePicker `format` (display format)" },
            "size": { "type": "string", "enum": ["small", "middle", "large"], "description": "antd RangePicker `size`" },
            "allowClear": { "type": "boolean", "description": "antd RangePicker `allowClear`" },
            "disabled": { "type": "boolean", "description": "antd RangePicker `disabled`" }
          }
        },
        "apiRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "required": ["name", "namespace"],
          "additionalProperties": false
        },
        "widgetDataTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "forPath": { "type": "string" },
              "expression": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "resourcesRefs": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "allowed": { "type": "boolean" },
                  "apiVersion": { "type": "string" },
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "namespace": { "type": "string" },
                  "payload": { "type": "object" },
                  "resource": { "type": "string" },
                  "verb": {
                    "type": "string",
                    "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"]
                  },
                  "slice": {
                    "type": "object",
                    "properties": {
                      "offset": { "type": "integer" },
                      "page": { "type": "integer" },
                      "perPage": { "type": "integer" },
                      "continue": { "type": "boolean" }
                    },
                    "required": ["page", "perPage"]
                  }
                },
                "required": ["id"]
              }
            }
          },
          "required": ["items"]
        },
        "resourcesRefsTemplate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iterator": { "type": "string" },
              "template": {
                "type": "object",
                "properties": {
                  "apiVersion": { "type": "string" },
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "namespace": { "type": "string" },
                  "payload": { "type": "object" },
                  "resource": { "type": "string" },
                  "verb": {
                    "type": "string",
                    "enum": ["POST", "PUT", "PATCH", "DELETE", "GET"]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": ["kind", "spec", "version"]
}
